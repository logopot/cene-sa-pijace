# Path to the downloaded Google Service Account JSON key file.
# Share the target spreadsheet with this service account's email (Editor access).
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# ID of the target Google Sheet (the long id in the sheet's URL).
GOOGLE_SHEETS_SPREADSHEET_ID=

# Name of the sheet/tab to write price rows into.
GOOGLE_SHEETS_SHEET_NAME=Prices

# STIPS site base URL.
STIPS_BASE_URL=https://www.stips.minpolj.gov.rs

# Which week(s) to scrape: "latest" (most recent week with a completed date
# range), "all" (every completed week for STIPS_YEAR - use for historical
# backfills), or an explicit STIPS internal nedelja id (see stipsClient.listWeeks).
STIPS_WEEK=latest

# Year to scrape weeks for.
STIPS_YEAR=2026
