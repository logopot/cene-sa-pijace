# Path to the downloaded Google Service Account JSON key file (the same
# service account the STIPS scraper uses - share the target spreadsheet
# with it once, then both scrapers can reuse the same key file).
GOOGLE_APPLICATION_CREDENTIALS=../stips-scraper/service-account.json

# ID of the target Google Sheet (same spreadsheet the STIPS scraper writes to).
GOOGLE_SHEETS_SPREADSHEET_ID=

# Name of the sheet/tab to append JKP price rows into. Created automatically
# on first run if it doesn't exist yet.
JKP_SHEET_NAME=JKP_Prices

# bgpijace.rs base URL.
JKP_BGPIJACE_BASE_URL=https://www.bgpijace.rs

# Which barometar date(s) to scrape: "latest" (most recently published
# date), "all" (every date bgpijace.rs still lists in its barometar
# dropdown), or an explicit date in YYYY-MM-DD form.
JKP_DATE=latest

# Alternative to JKP_DATE above: backfill just the dropdown dates that fall
# within this inclusive YYYY-MM-DD window (either bound is optional). See
# backfill.js for a fixed, one-off example of this.
JKP_DATE_FROM=
JKP_DATE_TO=
